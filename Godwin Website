<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Godwin Ebuka | Web Developer</title>

  <!-- AOS CSS -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

  <!-- Swiper CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css"/>

  <!-- Paystack JS -->
  <script src="https://js.paystack.co/v1/inline.js"></script>

  <style>
    /* Global Styles */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }
    html {
      scroll-behavior: smooth;
    }
    body {
      background: linear-gradient(-45deg,#1f1c2c,#928dab,#1f1c2c,#ffcc00);
      background-size: 400% 400%;
      animation: gradientBG 20s ease infinite;
      color: white;
      position: relative;
      overflow-x: hidden;
      transition: 0.5s;
    }
    body.dark {
      background: #121212;
      color: #e0e0e0;
    }
    body.dark input, body.dark select, body.dark form {
      background: #1e1e1e;
      color: #fff;
    }

    /* Robot Background */
    body::before {
      content:"";
      background: url('https://i.imgur.com/2yYayZk.png') no-repeat center center/contain;
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      opacity: 0.05;
      z-index: 0;
    }

    /* Floating Particles */
    .particle {
      position: absolute;
      border-radius: 50%;
      background: #ffd700;
      opacity: 0.6;
      animation: floatParticles 20s linear infinite;
    }

    @keyframes floatParticles {
      0% { transform: translateY(0) translateX(0); }
      50% { transform: translateY(-1000px) translateX(500px); }
      100% { transform: translateY(0) translateX(0); }
    }

    @keyframes gradientBG {
      0% { background-position:0% 50%; }
      50% { background-position:100% 50%; }
      100% { background-position:0% 50%; }
    }

    /* Navigation */
    nav {
      position: fixed;
      top: 0; left: 0;
      width: 100%;
      background: rgba(0,0,0,0.7);
      display: flex;
      justify-content: center;
      padding: 15px 0;
      z-index: 100;
      backdrop-filter: blur(5px);
    }
    nav a, nav button {
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
      transition: 0.3s;
      cursor: pointer;
      border: none;
      border-radius: 5px;
    }
    nav a {
      color: #ffd700;
    }
    nav a:hover, nav a.active {
      color: #fff;
      transform: scale(1.1);
    }
    nav button {
      padding: 8px 15px;
      background: #ffd700;
      color: #000;
    }
    nav button:hover {
      transform: scale(1.05);
    }

    /* Header */
    header {
      text-align: center;
      padding: 140px 20px 60px 20px;
      position: relative;
      z-index: 10;
    }
    header h1 {
      font-size: 48px;
      color: #ffd700;
      text-shadow: 0 0 20px #ffd700,0 0 40px #ffd700;
      animation: glow 2s ease-in-out infinite alternate;
    }
    @keyframes glow {
      from { text-shadow: 0 0 10px #ffd700,0 0 20px #ffd700; }
      to { text-shadow: 0 0 20px #ffd700,0 0 40px #ffd700; }
    }
    #typing-text {
      font-size: 22px;
      max-width: 700px;
      margin: auto;
      line-height: 1.6;
      color: #fff8dc;
      min-height: 60px;
    }
    .cursor {
      display: inline-block;
      width: 3px;
      background: #ffd700;
      margin-left: 5px;
      animation: blink 0.7s infinite;
    }
    @keyframes blink {
      0%, 100% { opacity:1; }
      50% { opacity:0; }
    }

    /* Sections */
    section {
      padding: 80px 20px;
      position: relative;
      z-index: 2;
    }
    .about, .services, .projects, .testimonials, .contact {
      border-radius: 20px;
      max-width: 1000px;
      margin: 50px auto;
      padding: 50px 20px;
    }

    /* About */
    .about { background: #6d4c41; color: #fff8dc; }
    .about-container {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 40px;
    }
    .about img {
      width: 250px;
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .about-text { max-width: 500px; }

    /* Services */
    .services { background: #4e342e; text-align: center; color: #fff; }
    .services h2 { color: #ffd700; margin-bottom: 30px; }
    .service-list {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 30px;
      margin-top: 40px;
    }
    .service-item {
      background: rgba(255,255,255,0.06);
      padding: 30px;
      width: 280px;
      border-radius: 20px;
      backdrop-filter: blur(10px);
      transition: 0.4s;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    .service-item:hover {
      transform: translateY(-12px);
      box-shadow: 0 15px 40px rgba(255,215,0,0.3);
    }
    .service-item h3 { color: #ffd700; margin-bottom: 10px; }
    .service-item small {
      display: block;
      margin-top: 15px;
      color: #ffd700;
      font-style: italic;
      font-size: 14px;
    }

    /* Projects */
    .projects { background: #5d4037; text-align: center; color: #fff; }
    .project-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
      gap: 30px;
      margin-top: 40px;
    }
    .project-item {
      position: relative;
      overflow: hidden;
      border-radius: 15px;
      cursor: pointer;
    }
    .project-item img {
      width: 100%;
      transition: 0.3s;
    }
    .project-item:hover img { transform: scale(1.1); }
    .project-item div {
      position: absolute;
      bottom: 0;
      width: 100%;
      background: rgba(0,0,0,0.7);
      color: #ffd700;
      padding: 10px;
      text-align: center;
      opacity: 0;
      transition: 0.3s;
    }
    .project-item:hover div { opacity: 1; }

    /* Testimonials */
    .testimonials { background: #6d4c41; text-align: center; color: #fff; }
    .testimonials h2 { color: #ffd700; margin-bottom: 40px; }
    .testimonial-container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 30px;
      margin-top: 40px;
    }
    .testimonial-card {
      background: rgba(255,255,255,0.06);
      padding: 35px;
      width: 300px;
      border-radius: 20px;
      backdrop-filter: blur(10px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      transition: 0.4s;
    }
    .testimonial-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 40px rgba(255,215,0,0.4);
    }
    .testimonial-card img {
      width: 80px; height: 80px;
      border-radius: 50%;
      border: 3px solid #ffd700;
      margin-bottom: 15px;
    }
    .testimonial-card h3 { color: #ffd700; margin-bottom: 5px; }
    .testimonial-card span { font-size: 13px; opacity: 0.7; }
    .stars { color: #ffd700; margin: 10px 0; font-size: 18px; letter-spacing: 2px; }

    /* Contact */
    .contact form {
      background: #6d4c41;
      padding: 30px;
      border-radius: 20px;
      max-width: 600px;
      margin: 50px auto;
      color: #fff8dc;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .contact form h2 { text-align: center; margin-bottom: 20px; color: #ffd700; }
    .contact form label { display: block; margin: 10px 0 5px; }
    .contact form input, .contact form select {
      width: 100%;
      padding: 10px;
      border-radius: 10px;
      border: none;
      margin-bottom: 15px;
    }
    .contact form button {
      width: 100%;
      padding: 12px;
      font-size: 18px;
      border: none;
      border-radius: 50px;
      background: linear-gradient(90deg,#ffd700,#b8860b);
      color: #000;
      cursor: pointer;
      box-shadow: 0 0 20px #ffd700;
      transition: 0.3s;
    }
    .contact form button:hover {
      transform: scale(1.05);
      box-shadow: 0 0 40px #ffd700;
    }

    /* Footer */
    footer {
      background: #3e2723;
      padding: 20px;
      text-align: center;
      font-size: 14px;
      color: #ffd700;
      border-radius: 10px;
    }
  </style>
</head>

<body>

  <!-- Navigation -->
  <nav>
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <a href="#services">Services</a>
    <a href="#projects">Projects</a>
    <a href="#testimonials">Testimonials</a>
    <a href="#contact">Contact</a>
    <button onclick="toggleDark()">Dark Mode</button>
  </nav>

  <!-- Floating Particles -->
  <div class="particle" style="width:8px; height:8px; top:10%; left:15%; animation-duration:25s;"></div>
  <div class="particle" style="width:12px; height:12px; top:50%; left:30%; animation-duration:30s;"></div>
  <div class="particle" style="width:6px; height:6px; top:80%; left:70%; animation-duration:20s;"></div>
  <div class="particle" style="width:10px; height:10px; top:30%; left:85%; animation-duration:35s;"></div>
  <div class="particle" style="width:14px; height:14px; top:60%; left:60%; animation-duration:40s;"></div>

  <!-- Header -->
  <header id="home">
    <h1 data-aos="fade-down">Godwin Ebuka</h1>
    <h2 id="typing-text"></h2>
  </header>

  <!-- About -->
  <section class="about" id="about" data-aos="fade-up">
    <div class="about-container">
      <img src="https://media.istockphoto.com/id/2178014330/photo/happy-african-guy-with-laptop-over-studio-background.jpg?s=612x612&w=0&k=20&c=ymtjHPvmUT8nF4knR_xxI2iHLgdNm5RnBTDuVW16VGg=" alt="Godwin Photo">
      <div class="about-text">
        <h2>About Me</h2>
        <p>I am a website developer focused on creating high-performance, visually stunning websites that help people grow.</p>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="services" id="services" data-aos="fade-up">
    <h2>My Services</h2>
    <div class="service-list">
      <div class="service-item">
        <h3>Web Development</h3>
        <p>Modern, responsive and high-performance websites built for growth.</p>
        <small>"Transforming ideas into scalable digital solutions."</small>
      </div>
      <div class="service-item">
        <h3>Graphic Design</h3>
        <p>Creative branding, logos and professional visual identity.</p>
        <small>"Design that speaks before you say a word."</small>
      </div>
      <div class="service-item">
        <h3>Business Portfolio</h3>
        <p>Professional websites that attract clients and increase trust.</p>
        <small>"Your brand deserves a powerful online presence."</small>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="projects" id="projects" data-aos="fade-up">
    <h2>Projects</h2>
    <div class="project-list">
      <div class="project-item">
        <img src="https://www.bing.com/th/id/OIP.6rHQ9X-6GqJ7lCp4MMUsVAHaE8?w=253&h=211&c=8&rs=1&qlt=90&o=6&dpr=1.5&pid=3.1&rm=2/300x200">
        <div>Portfolio Website</div>
      </div>
      <div class="project-item">
        <img src="https://www.bing.com/th/id/OIP.uY6ukko_YG3KQeXSnnKyXAHaE7?w=253&h=211&c=8&rs=1&qlt=90&o=6&dpr=1.5&pid=3.1&rm=2/300x200">
        <div>Business Website</div>
      </div>
      <div class="project-item">
        <img src="https://www.bing.com/th/id/OIP.MByFw1Th48PcEzLBSSV30wHaEc?w=248&h=211&c=8&rs=1&qlt=90&o=6&dpr=1.5&pid=3.1&rm=2/300x200">
        <div>Graphic Design Projects</div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials" id="testimonials" data-aos="fade-up">
    <h2>Client Testimonials</h2>
    <div class="testimonial-container">
      <div class="testimonial-card">
        <img src="https://i.pravatar.cc/100?img=12" alt="Client">
        <h3>Michael Chris</h3>
        <span>CEO, Tech Solutions</span>
        <div class="stars">★★★★★</div>
        <p>"Godwin delivered a premium website that increased our online visibility and customer engagement."</p>
      </div>
      <div class="testimonial-card">
        <img src="https://i.pravatar.cc/100?img=32" alt="Client">
        <h3>Sarah Rose</h3>
        <span>Marketing Director</span>
        <div class="stars">★★★★★</div>
        <p>"Professional, creative and highly reliable. Excellent work quality and fast delivery."</p>
      </div>
      <div class="testimonial-card">
        <img src="https://i.pravatar.cc/100?img=45" alt="Client">
        <h3>David Brown</h3>
        <span>Entrepreneur</span>
        <div class="stars">★★★★★</div>
        <p>"Outstanding communication and world-class website designer. Highly recommended."</p>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact" data-aos="fade-up">
    <form onsubmit="sendWhatsApp(event)">
      <h2>Get in Touch</h2>
      <label>Name</label>
      <input type="text" id="name" placeholder="Your Name" required>

      <label>Gender</label>
      <select id="gender" required>
        <option value="">Select Gender</option>
        <option value="male">Male</option>
        <option value="female">Female</option>
        <option value="other">Other</option>
      </select>

      <label>Phone</label>
      <input type="tel" id="phone" placeholder="Your Phone Number" required>

      <label>Service</label>
      <select id="service" required>
        <option value="">Select Service</option>
        <option value="web-developer">Web Developer</option>
        <option value="graphic-design">Graphic Design</option>
        <option value="business-portfolio">Business Portfolio</option>
      </select>

      <button type="submit">Submit via WhatsApp</button>
    </form>
  </section>

  <footer>© 2026 Godwin Ebuka | All Rights Reserved</footer>

  <!-- Scripts -->
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
  <script>
    // Initialize AOS
    AOS.init({
      duration: 1500,
      once: true,
      easing: 'ease-in-out',
      offset: 120
    });

    // Typing Animation
    const text = "I am a website developer focused on creating high-performance, visually stunning websites that help people grow.";
    let index = 0;
    const speed = 30;
    const typingElement = document.getElementById("typing-text");
    function typeEffect(){
      if(index < text.length){
        typingElement.innerHTML += text.charAt(index);
        index++;
        setTimeout(typeEffect, speed);
      } else {
        typingElement.innerHTML += '<span class="cursor"></span>';
      }
    }
    typeEffect();

    // WhatsApp Contact
    function sendWhatsApp(e){
      e.preventDefault();
      const name = document.getElementById("name").value;
      const gender = document.getElementById("gender").value;
      const phone = document.getElementById("phone").value;
      const service = document.getElementById("service").value;
      const message = `Hello Godwin!%0AName: ${name}%0AGender: ${gender}%0APhone: ${phone}%0AService: ${service}`;
      window.open(`https://wa.me/2349138258792?text=${message}`, "_blank");
    }

    // Dark Mode Toggle
    function toggleDark(){
      document.body.classList.toggle("dark");
    }
  </script>
</body>
</html>

